# Copy this file to .env for local `vercel dev`, and add the same keys
# in your Vercel project's Environment Variables settings for production.

# --- Supabase (Project Settings -> API) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- MercadoPago (Your integrations -> Credentials -> Production/Test access token) ---
MERCADOPAGO_ACCESS_TOKEN=

# --- Resend (API Keys) ---
RESEND_API_KEY=
# Must be "onboarding@resend.dev" until you verify your own sending domain in Resend.
RESEND_FROM_EMAIL=La Laundry <onboarding@resend.dev>
# Your own inbox — gets an email every time a booking is confirmed, so you
# don't have to keep checking the bookings table. Leave empty to disable.
# Supports multiple comma-separated addresses, e.g. owner@x.com, staff@x.com
OWNER_NOTIFICATION_EMAIL=

# --- Google Maps (Google Cloud Console -> APIs & Services -> Credentials) ---
# Needs "Maps JavaScript API" and "Places API" enabled, billing enabled on the
# project, and the key restricted (HTTP referrers) to your domain(s). This is
# a browser-side key (VITE_ prefix ships it in the JS bundle) — that's normal
# for Google Maps; the referrer restriction is what keeps it safe to use.
VITE_GOOGLE_MAPS_API_KEY=

# --- App ---
# Absolute https URL of the deployed site. Required for MercadoPago back_urls
# and the webhook notification_url — MercadoPago will not call back to localhost.
SITE_URL=https://your-app.vercel.app
# Deposit charged upfront for "pagar en línea ahora", in MXN.
DEPOSIT_AMOUNT_MXN=300
# Max bookings allowed per day + 2-hour slot combo (e.g. "viernes 17 de
# julio, 9am-11am"). Once reached, that slot is grayed out on the site and
# rejected server-side if someone still tries to book it. Defaults to 5.
MAX_BOOKINGS_PER_SLOT=5

# --- Internal ops app (existing separate Supabase project) ---
# Every confirmed booking is also relayed via POST to this endpoint so it
# shows up in the internal ops app too (best-effort — never blocks the
# customer's booking if it fails). Optional: defaults to
# https://app.lalaundry.xyz/api/agendar if left empty.
OPS_AGENDAR_URL=
